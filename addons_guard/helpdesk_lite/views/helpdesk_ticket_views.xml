<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_helpdesk_ticket_form" model="ir.ui.view">
        <field name="name">helpdesk.ticket.form</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <form string="Helpdesk Ticket">
                <header>
                    <field name="state" widget="statusbar" statusbar_visible="new,in_progress,resolved,closed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="assigned_to"/>
                        </group>
                        <group>
                            <field name="priority"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_helpdesk_ticket_list" model="ir.ui.view">
        <field name="name">helpdesk.ticket.list</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="assigned_to"/>
                <field name="priority"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="action_helpdesk_ticket" model="ir.actions.act_window">
        <field name="name">Helpdesk Tickets</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_helpdesk_root"
              name="Helpdesk"
              sequence="95"/>

    <menuitem id="menu_helpdesk_tickets"
              name="Tickets"
              parent="menu_helpdesk_root"
              action="action_helpdesk_ticket"
              sequence="10"/>

</odoo>
