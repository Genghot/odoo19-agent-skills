<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Search View -->
    <record id="view_helpdesk_ticket_search" model="ir.ui.view">
        <field name="name">helpdesk.ticket.search</field>
        <field name="model">helpdesk.ticket</field>
        <field name="arch" type="xml">
            <search string="Search Tickets">
                <field name="name" string="Ticket"/>
                <field name="assigned_to"/>
                <separator/>
                <filter string="My Tickets" name="my_tickets"
                        domain="[('assigned_to', '=', uid)]"/>
                <filter string="High Priority" name="high_priority"
                        domain="[('priority', 'in', ('high', 'urgent'))]"/>
                <filter string="Open" name="open"
                        domain="[('state', 'not in', ('resolved', 'closed'))]"/>
                <separator/>
                <filter string="Create Date" name="create_date"
                        date="create_date"/>
                <group>
                    <filter string="State" name="group_state"
                            context="{'group_by': 'state'}"/>
                    <filter string="Priority" name="group_priority"
                            context="{'group_by': 'priority'}"/>
                    <filter string="Assigned To" name="group_assigned_to"
                            context="{'group_by': 'assigned_to'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action with default search context -->
    <record id="action_helpdesk_ticket_search" model="ir.actions.act_window">
        <field name="name">Helpdesk Tickets</field>
        <field name="res_model">helpdesk.ticket</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_helpdesk_ticket_search"/>
        <field name="context">{
            'search_default_my_tickets': 1,
            'search_default_open': 1,
        }</field>
    </record>

</odoo>
