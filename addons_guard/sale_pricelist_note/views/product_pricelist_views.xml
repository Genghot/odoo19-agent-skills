<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit Pricelist Form: add internal_note and discount_reason column -->
    <record id="product_pricelist_view_inherit_note" model="ir.ui.view">
        <field name="name">product.pricelist.form.inherit.note</field>
        <field name="model">product.pricelist</field>
        <field name="inherit_id" ref="product.product_pricelist_view"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="before">
                <group>
                    <field name="internal_note" placeholder="Internal notes about this pricelist..."/>
                </group>
            </xpath>
            <xpath expr="//field[@name='item_ids']//list//field[@name='date_end']" position="after">
                <field name="discount_reason" optional="show"/>
            </xpath>
        </field>
    </record>

    <!-- Inherit Pricelist Item List View -->
    <record id="product_pricelist_item_tree_view_inherit_reason" model="ir.ui.view">
        <field name="name">product.pricelist.item.list.inherit.reason</field>
        <field name="model">product.pricelist.item</field>
        <field name="inherit_id" ref="product.product_pricelist_item_tree_view"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_end']" position="after">
                <field name="discount_reason" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
