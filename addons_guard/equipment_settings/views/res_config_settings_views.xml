<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Settings View: inherit base settings form -->
    <record id="res_config_settings_view_form_equipment" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.equipment</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <!-- Use //form position=inside, NOT //app[@name='general'] -->
            <xpath expr="//form" position="inside">
                <app data-string="Equipment Tracking" string="Equipment Tracking">
                    <block title="Serial Tracking">
                        <setting string="Serial Tracking"
                                 help="Enable serial number tracking for equipment.">
                            <field name="use_serial_tracking"/>
                        </setting>
                    </block>
                    <block title="Default Status">
                        <setting string="Default Equipment Status"
                                 help="Set the default status for newly created equipment.">
                            <field name="default_equipment_status"/>
                        </setting>
                    </block>
                </app>
            </xpath>
        </field>
    </record>

</odoo>
