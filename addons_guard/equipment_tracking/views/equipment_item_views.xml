<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_equipment_item_form" model="ir.ui.view">
        <field name="name">equipment.item.form</field>
        <field name="model">equipment.item</field>
        <field name="arch" type="xml">
            <form string="Equipment Item">
                <header>
                    <field name="status" widget="statusbar" statusbar_visible="available,in_use,maintenance,retired"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="serial_number"/>
                            <field name="purchase_date"/>
                        </group>
                        <group>
                            <field name="assigned_to"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="notes"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_equipment_item_list" model="ir.ui.view">
        <field name="name">equipment.item.list</field>
        <field name="model">equipment.item</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="serial_number"/>
                <field name="purchase_date"/>
                <field name="status"/>
                <field name="assigned_to"/>
            </list>
        </field>
    </record>

    <record id="action_equipment_item" model="ir.actions.act_window">
        <field name="name">Equipment Items</field>
        <field name="res_model">equipment.item</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_equipment_root"
              name="Equipment"
              sequence="90"/>

    <menuitem id="menu_equipment_items"
              name="Equipment Items"
              parent="menu_equipment_root"
              action="action_equipment_item"
              sequence="10"/>

</odoo>
