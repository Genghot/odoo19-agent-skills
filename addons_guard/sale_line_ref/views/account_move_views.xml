<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Inherit Invoice Form: add customer_ref to invoice line list -->
    <record id="view_move_form_inherit_line_ref" model="ir.ui.view">
        <field name="name">account.move.form.inherit.line.ref</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_line_ids']//list//field[@name='quantity']" position="before">
                <field name="customer_ref" optional="show"/>
            </xpath>
        </field>
    </record>

</odoo>
